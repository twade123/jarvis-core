# ────────────────────────────────────────────────────────────────
# Jarvis Core — example environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────────────

# ── Anthropic API (for BoardRoom seats using Claude + fallback) ─
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OpenAI / other LLMs (optional, BoardRoom GPT seats) ─────────
# OPENAI_API_KEY=sk-your-key-here

# ── Local MLX serving ───────────────────────────────────────────
# Path to the LoRA adapter for the local Qwen3.5 35B model.
# Adapter weights are not in this repo — publish separately.
VMLX_ADAPTER_PATH=/path/to/your/35b_mlx_adapter
MLX_SERVER_HOST=127.0.0.1
MLX_SERVER_PORT=11500

# ── OANDA (if running the forex trading workspace) ──────────────
# See separate repo: github.com/twade123/forex-trading-team
# OANDA_API_KEY=your-oanda-token
# OANDA_ACCOUNT_ID=000-000-0000000-000
# OANDA_ENVIRONMENT=demo

# ── External tool APIs (optional) ───────────────────────────────
# WOLFRAM_API_KEY=your-wolfram-app-id
# GHL_API_KEY=your-gohighlevel-key

# ── User / tenant ID ────────────────────────────────────────────
JARVIS_USER_ID=1

# ── Mode flags ──────────────────────────────────────────────────
JARVIS_TRADING_MODE=0           # 1 enables trading-team workspace
JARVIS_VOICE_MODE=1             # 1 enables Whisper voice pipeline

# ── UI / serving ────────────────────────────────────────────────
TREVOR_UI_PORT=8766             # serve_ui.py Flask + SSE
TREVOR_UI_HOST=127.0.0.1
